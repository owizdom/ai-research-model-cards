# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=policy
POSTGRES_PASSWORD=policy
POSTGRES_DB=policy_intel
DATABASE_URL=postgresql+asyncpg://policy:policy@db:5432/policy_intel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000
SECRET_KEY=change-me-in-production

# ── Web ───────────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── LLM API Keys (for eval extraction) ──────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=

# ── Worker ────────────────────────────────────────────────────────────────────
DATA_DIR=/app/data

# ── Eval Extraction ──────────────────────────────────────────────────────────
EXTRACTION_MODEL=claude-sonnet-4-6

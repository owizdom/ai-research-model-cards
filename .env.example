# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=policy
POSTGRES_PASSWORD=policy
POSTGRES_DB=policy_intel
DATABASE_URL=postgresql+asyncpg://policy:policy@db:5432/policy_intel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000
SECRET_KEY=change-me-in-production

# ── Web ───────────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Eval Extraction ──────────────────────────────────────────────────────────
# Default uses Claude Sonnet 4.6 via OAuth (Max subscription quota).
# Mint a long-lived token with `claude setup-token` (or, if the Ink TTY errors,
# `script -q /dev/null claude setup-token < /dev/null`). Token format: sk-ant-oat01-...
CLAUDE_CODE_OAUTH_TOKEN=
EXTRACTION_MODEL=sonnet
EXTRACT_WORKERS=3

# Fallback path — set EXTRACTION_MODEL to a non-Claude model and uncomment a key:
# EXTRACTION_MODEL=groq/llama-3.3-70b-versatile
# GROQ_API_KEY=
# GEMINI_API_KEY=

# ── Worker ────────────────────────────────────────────────────────────────────
DATA_DIR=/app/data
